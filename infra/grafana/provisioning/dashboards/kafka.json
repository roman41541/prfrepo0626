            "displayMode": "list",
            "placement": "bottom"
          }
        },
        "targets": [
          {
            "expr": "kafka_consumergroup_lag{job=\"kafka-exporter\"}",
            "legendFormat": "{{consumergroup}} / {{topic}} / p{{partition}}"
          }
        ],
        "title": "Consumer Group Lag",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"

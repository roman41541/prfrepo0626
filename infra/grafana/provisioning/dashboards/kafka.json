        "description": "Количество доступных брокеров Kafka. Если значение падает — exporter не видит часть кластера или брокеры недоступны.",
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          },
          "overrides": []
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "id": 1,
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        },
        "targets": [
          {
            "expr": "kafka_brokers{job=\"kafka-exporter\"}",
            "legendFormat": "brokers"
          }
        ],
        "title": "Kafka Brokers Count",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "description": "Количество partition по топикам Kafka.",
